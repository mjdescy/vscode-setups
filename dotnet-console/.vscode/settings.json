{
    // ===== .NET / C# =====
    "dotnet.enablePackageRestore": true,

    // Use file-scoped namespaces by default (C# 10+)
    "omnisharp.enableFileScopedNamespace": true,

    // Enable Roslyn analyzers
    "omnisharp.enableRoslynAnalyzers": true,

    // Enable .NET code analysis
    "omnisharp.enableAnalyzersForAllProjects": true,

    // Format on save using dotnet-format
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "[csharp]": {
        "editor.defaultFormatter": "ms-dotnettools.csharp",
        "editor.tabSize": 4,
        "editor.insertSpaces": true
    },

    // Use .editorconfig for style rules
    "omnisharp.useEditorConfigFile": true,

    // ===== Testing =====
    "dotnet-test-explorer.testProjectPath": "tests/**/*.Tests.csproj",
    "dotnetTestExplorer.enableTelemetry": false,

    // ===== General Editor =====
    "files.exclude": {
        "**/bin/**": true,
        "**/obj/**": true,
        "**/.vs/**": true
    },
    "files.autoSave": "onFocusChange",
    "workbench.colorTheme": "Default Dark Modern",
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "boundary",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,

    // ===== Terminal =====
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.fontSize": 13,

    // ===== Explorer =====
    "explorer.compactFolders": false
}
