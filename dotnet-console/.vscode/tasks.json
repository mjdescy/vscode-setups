{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Install All Recommended Extensions",
            "type": "shell",
            "command": "jq -r '.recommendations[]' ./.vscode/extensions.json | xargs -L 1 code --install-extension",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "build",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}",
                "--no-restore"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "build (clean)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "build",
                "${workspaceFolder}"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "test",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}",
                "--no-restore"
            ],
            "problemMatcher": "$msCompile",
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "test (with coverage)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "test",
                "${workspaceFolder}",
                "--no-restore",
                "--collect:\"XPlat Code Coverage\"",
                "--results-directory:TestResults"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "format",
            "command": "dotnet",
            "type": "process",
            "args": [
                "format",
                "${workspaceFolder}",
                "--verify-no-changes"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "publish (Release)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "publish",
                "${workspaceFolder}/src/${workspaceFolderBasename}.Console/${workspaceFolderBasename}.Console.csproj",
                "-c",
                "Release",
                "-o",
                "${workspaceFolder}/publish"
            ],
            "problemMatcher": "$msCompile"
        },
        {
            "label": "watch (build)",
            "command": "dotnet",
            "type": "process",
            "args": [
                "watch",
                "--project",
                "${workspaceFolder}/src/${workspaceFolderBasename}.Console/${workspaceFolderBasename}.Console.csproj",
                "build"
            ],
            "problemMatcher": "$msCompile"
        }
    ]
}
