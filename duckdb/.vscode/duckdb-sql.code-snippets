    "Pull Reservoir Sample (exact rows + seed)": {
        "prefix": ["reservoir-sample", "sample-reservoir"],
        "scope": "sql",
        "body": [
            "SELECT *",
            "FROM ${1:table_name}",
            "USING SAMPLE reservoir(${2:100} ROWS)",
            "REPEATABLE (${3:42});",
            "$0"
        ],
        "description": "DuckDB: sample exact rows with reservoir sampling and a repeatable seed"
    }
