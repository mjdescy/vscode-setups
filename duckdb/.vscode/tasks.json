{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Install All Recommended Extensions",
            "type": "shell",
            "command": "jq -r '.recommendations[]' ./.vscode/extensions.json | xargs -L 1 code --install-extension",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "Run SQL file",
            "type": "shell",
            "command": "duckdb",
            "args": [
                "${workspaceFolder}/data/database.duckdb",
                "<",
                "${file}"
            ],
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "Open DuckDB CLI",
            "type": "shell",
            "command": "duckdb",
            "args": [
                "${workspaceFolder}/data/database.duckdb"
            ],
            "group": "none",
            "problemMatcher": []
        }
    ]
}
