{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Install All Recommended Extensions",
            "type": "shell",
            "command": "jq -r '.recommendations[]' ./.vscode/extensions.json | xargs -L 1 code --install-extension",
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "reveal": "silent"
            }
        },
        {
            "label": "Python: create venv",
            "type": "shell",
            "command": "python3 -m venv .venv && ${workspaceFolder}/.venv/bin/pip install --upgrade pip",
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "Python: install dev deps",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/pip install pandas jupyter black ruff pytest",
            "group": "none",
            "problemMatcher": []
        },
        {
            "label": "Python: run tests",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/python -m pytest",
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Python: lint (ruff)",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/ruff check .",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Python: format (ruff)",
            "type": "shell",
            "command": "${workspaceFolder}/.venv/bin/ruff format .",
            "group": "build",
            "problemMatcher": []
        }
    ]
}
