{
    // ===== DuckDB (chuckjonas.duckdb) =====
    // The DuckDB extension provides syntax highlighting and language
    // support for .duckdb and .sql files. No additional config needed.

    // ===== Excel / CSV Viewer (grapecity.gc-excelviewer) =====
    // Right-click any .xlsx, .csv, or .tsv file and select "View" to
    // open it in a spreadsheet grid. No additional config needed.

    // ===== Parquet Explorer (AdamViola.parquet-explorer) =====
    // Right-click any .parquet file and select "Open Preview" to
    // browse its contents. No additional config needed.

    // ===== Editor =====
    "[sql]": {
        "editor.tabSize": 4,
        "editor.insertSpaces": true,
        "editor.formatOnSave": true,
        "editor.rulers": [100]
    },

    "files.autoSave": "onFocusChange",
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "boundary",
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": true,

    // DuckDB creates temporary files
    "files.exclude": {
        "**/*.tmp": true,
        "**/data/*.duckdb": true,
        "**/data/*.duckdb.wal": true
    },

    // ===== Terminal =====
    "terminal.integrated.defaultProfile.linux": "bash",
    "terminal.integrated.fontSize": 13,

    // ===== Explorer =====
    "explorer.compactFolders": false
}
