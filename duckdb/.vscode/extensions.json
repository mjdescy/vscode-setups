{
    "recommendations": [
        // SQLTools — multi-DB query runner (also supports DuckDB via driver)
        "mtxr.sqltools",

        // SQLTools DuckDB driver — connect to DuckDB databases
        "mtxr.sqltools-driver-duckdb",

        // DuckDB shell extension — run .duckdb queries inline
        "quackdb.duckdb-vscode",

        // Parquet file viewer and preview
        "RandomFractalsInc.vscode-parquet-viewer",

        // Inline SQL formatting for .sql and .duckdb files
        "adpyke.vscode-sql-formatter"
    ]
}
