{
    "Import CSV": {
        "prefix": ["csv-import", "readcsv"],
        "scope": "sql",
        "body": [
            "CREATE OR REPLACE TABLE ${1:table_name} AS",
            "SELECT *",
            "  FROM read_csv('${2:path/to/file.csv}');",
            "$0"
        ],
        "description": "DuckDB: import CSV into a table"
    },

    "Import CSV (All Varchar)": {
        "prefix": ["csv-import-varchar"],
        "scope": "sql",
        "body": [
            "CREATE OR REPLACE TABLE ${1:table_name} AS",
            "SELECT *",
            "  FROM read_csv('${2:path/to/file.csv}',",
            "    all_varchar = true",
            "  );",
            "$0"
        ],
        "description": "DuckDB: import CSV into a table with all columns as VARCHAR"
    },

    "Export to CSV": {
        "prefix": ["csv-export", "writecsv"],
        "scope": "sql",
        "body": [
            "COPY ${1:table_or_query} TO '${2:output/file.csv}'",
            "  (FORMAT CSV, HEADER true, DELIMITER ',');",
            "$0"
        ],
        "description": "DuckDB: export table/query to CSV"
    },

