{
    "version": "0.2.0",
    "configurations": [
        {
            // Launch the console app with optional arguments
            "name": "Run Console App",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/${workspaceFolderBasename}.Console/bin/Debug/net10.0/${workspaceFolderBasename}.Console.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            // Launch with --help to verify CLI parsing
            "name": "Run with --help",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/src/${workspaceFolderBasename}.Console/bin/Debug/net10.0/${workspaceFolderBasename}.Console.dll",
            "args": ["--help"],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            // Attach to an existing .NET process
            "name": "Attach to .NET Process",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}"
        }
    ]
}
